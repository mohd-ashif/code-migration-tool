{
  "info": {
    "name": "Migration Tool Backend API",
    "description": "Complete API collection for the Migration Tool Backend.\n\nSupported migration pairs:\n- Angular → React\n- Vue → React\n- JavaScript → TypeScript\n- React → TypeScript\n- React → Next.js\n\nSet the `baseUrl` variable to your server address (default: http://localhost:4000).\nSet the `apiKey` variable if API_KEY authentication is enabled.",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000", "type": "string" },
    { "key": "apiKey", "value": "your-api-key-here", "type": "string" },
    { "key": "jobId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "x-api-key", "type": "string" },
      { "key": "value", "value": "{{apiKey}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Server Health Check",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Check if the backend server is running. Returns the server status and available routes."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"ok\",\n  \"message\": \"Migration tool backend is running.\",\n  \"routes\": [\"/api/parse\", \"/api/migrate\", \"/api/report\", \"/api/download\"]\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Parse",
      "item": [
        {
          "name": "Parse Project (JSON)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectFiles\": [\n    {\n      \"path\": \"src/App.tsx\",\n      \"content\": \"import React from 'react';\\nconst App = () => <div>Hello</div>;\\nexport default App;\"\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/parse",
              "host": ["{{baseUrl}}"],
              "path": ["api", "parse"]
            },
            "description": "Parse project files sent as JSON. Detects the framework (Angular, Vue, React, TypeScript, JavaScript) from the file contents."
          },
          "response": [
            {
              "name": "Success - React Detected",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"framework\": \"react\",\n    \"files\": [],\n    \"metadata\": {}\n  }\n}"
            }
          ]
        },
        {
          "name": "Parse Project (ZIP Upload)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "project",
                  "type": "file",
                  "src": "",
                  "description": "Upload a .zip file containing the project source code"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/parse",
              "host": ["{{baseUrl}}"],
              "path": ["api", "parse"]
            },
            "description": "Parse a project by uploading a ZIP file. The backend extracts the ZIP and detects the framework automatically."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Migrate",
      "item": [
        {
          "name": "Migrate: Angular → React",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.jobId) {",
                  "    pm.collectionVariables.set('jobId', jsonData.jobId);",
                  "    console.log('Saved jobId: ' + jsonData.jobId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectFiles\": [\n    {\n      \"path\": \"src/app.component.ts\",\n      \"content\": \"import { Component } from '@angular/core';\\n\\n@Component({\\n  selector: 'app-root',\\n  template: '<div><h1>{{ title }}</h1><p>Welcome to Angular</p></div>'\\n})\\nexport class AppComponent {\\n  title = 'My Angular App';\\n}\"\n    }\n  ],\n  \"targetFramework\": \"react\",\n  \"sourceFramework\": \"angular\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/migrate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate"]
            },
            "description": "Migrate an Angular project to React. Converts Angular class components with decorators to React functional components."
          },
          "response": [
            {
              "name": "Success",
              "status": "Accepted",
              "code": 202,
              "body": "{\n  \"success\": true,\n  \"jobId\": \"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx\",\n  \"status\": \"pending\",\n  \"sourceFramework\": \"angular\"\n}"
            }
          ]
        },
        {
          "name": "Migrate: Vue → React",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
