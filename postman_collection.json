              "mode": "raw",
              "raw": "{\n  \"projectFiles\": [\n    {\n      \"path\": \"src/utils.js\",\n      \"content\": \"const greeting = 'Hello World';\\nconst add = (a, b) => a + b;\\nconst user = { name: 'John', age: 30 };\\n\\nfunction multiply(x, y) {\\n  return x * y;\\n}\\n\\nexport { greeting, add, user, multiply };\"\n    }\n  ],\n  \"targetFramework\": \"typescript\",\n  \"sourceFramework\": \"javascript\"\n}",
              "options": { "raw": { "language": "json" } }
