        {
          "name": "Check Migration Job Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/migrate/{{jobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "{{jobId}}"]
            },
            "description": "Poll the status of a migration job. Returns pending, completed, or failed status along with the migration result when complete."
          },
          "response": [
            {
              "name": "Success - Completed",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"job\": {\n    \"id\": \"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx\",\n    \"status\": \"completed\",\n    \"result\": {\n      \"success\": true,\n      \"targetFramework\": \"react\",\n      \"migratedFiles\": [],\n      \"metadata\": { \"fileCount\": 1, \"origin\": \"angular\" }\n    },\n    \"message\": null\n  }\n}"
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Job not found.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Report",
      "item": [
        {
          "name": "Generate Migration Report",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": \"{{jobId}}\",\n  \"summary\": \"Migration completed successfully.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/report",
              "host": ["{{baseUrl}}"],
              "path": ["api", "report"]
            },
            "description": "Generate or fetch a migration report for a completed job. Provide the jobId and an optional summary text."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"report\": {\n    \"jobId\": \"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx\",\n    \"summary\": \"Migration completed successfully.\",\n    \"timestamp\": \"2026-05-29T00:00:00.000Z\",\n    \"metrics\": {\n      \"migratedFiles\": 1,\n      \"warnings\": [],\n      \"errors\": []\n    }\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Download",
      "item": [
        {
          "name": "Download Migrated Files (ZIP)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/download?jobId={{jobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "download"],
              "query": [
                { "key": "jobId", "value": "{{jobId}}", "description": "The migration job ID returned by POST /api/migrate" }
              ]
            },
            "description": "Download the migrated project files as a ZIP archive. Requires a valid jobId from a completed migration job."
          },
          "response": []
        }
      ]
