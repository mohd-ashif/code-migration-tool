            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectFiles\": [\n    {\n      \"path\": \"src/App.vue\",\n      \"content\": \"<template>\\n  <div>\\n    <h1>{{ title }}</h1>\\n    <p v-if=\\\"showMessage\\\">Welcome to Vue</p>\\n    <ul>\\n      <li v-for=\\\"item in items\\\" :key=\\\"item\\\">{{ item }}</li>\\n    </ul>\\n  </div>\\n</template>\\n\\n<script>\\nexport default {\\n  data() {\\n    return {\\n      title: 'My Vue App',\\n      showMessage: true,\\n      items: ['Item 1', 'Item 2', 'Item 3']\\n    };\\n  }\\n};\\n</script>\"\n    }\n  ],\n  \"targetFramework\": \"react\",\n  \"sourceFramework\": \"vue\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/migrate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate"]
            },
            "description": "Migrate a Vue Single File Component (SFC) project to React JSX."
          },
          "response": []
        },
        {
